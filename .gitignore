# ===================================
# === MERN + TypeScript .gitignore 
# ===================================

# --- Dependencies ---
# Ignore all local dependency folders
node_modules/
client/node_modules/

# --- Build Output ---
# Ignore build, distribution, and cache folders
build/
dist/
.next/
.cache/
client/build/
client/dist/

# --- Secrets / Environment Variables (CRITICAL) ---
# Never commit secrets, API keys, or passwords
.env
.env.*
*.env
!.env.example

# --- Logs ---
# Ignore all log files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- TypeScript ---
# Ignore generated TypeScript cache files
*.tsbuildinfo
tsconfig.tsbuildinfo

# --- OS / System ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE / Editor ---
.vscode/
.idea/
*.iml
*.code-workspace
*.sublime-project
*.sublime-workspace

# --- Misc ---
*.tmp
*.bak
*.swp
*.seed

# --- Docker / Containerization ---
Dockerfile.local
docker-compose.override.yml
docker-data/
.env.docker

# --- Docker Volumes ---
mongo-data/
redis-data/
