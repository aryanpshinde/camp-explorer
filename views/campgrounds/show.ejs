<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/stars.css" />
<link rel="stylesheet" href="/stylesheets/campgrounds.css" />

<div class="row g-4">
  <!-- Left Column: Images & Details -->
  <div class="col-lg-6">
    <div
      id="campgroundCarousel"
      class="carousel slide carousel-fade shadow-sm rounded-4 overflow-hidden mb-4"
    >
      <div class="carousel-inner">
        <% campground.images.forEach((img, i) => { %>
        <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
          <img src="<%= img.url %>" class="d-block w-100" alt="" />
        </div>
        <% }) %>
      </div>
      <% if (campground.images.length > 1) { %>
      <button
        class="carousel-control-prev"
        type="button"
        data-bs-target="#campgroundCarousel"
        data-bs-slide="prev"
      >
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
      </button>
      <button
        class="carousel-control-next"
        type="button"
        data-bs-target="#campgroundCarousel"
        data-bs-slide="next"
      >
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
      </button>
      <% } %>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <h1 class="fw-bold mb-0"><%= campground.title %></h1>
          <span class="badge bg-success bg-opacity-10 text-success fs-6"
            >$<%= campground.price %>/night</span
          >
        </div>
        <p class="text-muted mb-4">
          <i class="bi bi-geo-alt-fill text-success me-2"></i><%=
          campground.location %>
        </p>
        <p class="card-text lead"><%= campground.description %></p>
        <hr />
        <p class="text-muted small mb-0">
          <i class="bi bi-person-fill me-1"></i>Submitted by
          <strong><%= campground.author.username %></strong>
        </p>
      </div>
      <% if (currentUser && campground.author.equals(currentUser._id)) { %>
      <div class="card-footer bg-transparent border-top-0 p-4 pt-0">
        <a
          class="btn btn-outline-info rounded-pill me-2"
          href="/campgrounds/<%= campground._id %>/edit"
        >
          <i class="bi bi-pencil-fill me-1"></i>Edit
        </a>
        <form
          class="d-inline"
          action="/campgrounds/<%= campground._id %>?_method=DELETE"
          method="POST"
        >
          <button class="btn btn-outline-danger rounded-pill">
            <i class="bi bi-trash-fill me-1"></i>Delete
          </button>
        </form>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Right Column: Map & Reviews -->
  <div class="col-lg-6">
    <!-- MapTiler Show Page Map -->
    <div id="map" class="rounded-4 shadow-sm mb-4"></div>

    <% if(currentUser) { %>
    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="card-body p-4">
        <h3 class="fw-bold mb-3">Leave a Review</h3>
        <form
          action="/campgrounds/<%= campground._id %>/reviews"
          method="POST"
          class="validated-form"
          novalidate
        >
          <div class="mb-3">
            <fieldset class="starability-grow">
              <input
                type="radio"
                id="no-rate"
                class="input-no-rate"
                name="review[rating]"
                value="1"
                checked
                aria-label="No rating."
              />
              <input
                type="radio"
                id="first-rate1"
                name="review[rating]"
                value="1"
              />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input
                type="radio"
                id="first-rate2"
                name="review[rating]"
                value="2"
              />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input
                type="radio"
                id="first-rate3"
                name="review[rating]"
                value="3"
              />
              <label for="first-rate3" title="Average">3 stars</label>
              <input
                type="radio"
                id="first-rate4"
                name="review[rating]"
                value="4"
              />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input
                type="radio"
                id="first-rate5"
                name="review[rating]"
                value="5"
              />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold" for="body">Your Thoughts</label>
            <textarea
              class="form-control"
              name="review[body]"
              id="body"
              cols="30"
              rows="3"
              placeholder="What did you think of this campground?"
              required
            ></textarea>
            <div class="valid-feedback">Looks good!</div>
          </div>
          <button class="btn btn-success rounded-pill px-4">
            Submit Review
          </button>
        </form>
      </div>
    </div>
    <% } %>

    <h3 class="fw-bold mb-3">Reviews</h3>
    <% if(campground.reviews.length === 0) { %>
    <p class="text-muted">No reviews yet. Be the first to leave one!</p>
    <% } %> <% for(let review of campground.reviews) { %>
    <div class="card border-0 shadow-sm rounded-4 mb-3">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h5 class="card-title mb-0 fw-bold"><%= review.author.username %></h5>
          <% if(currentUser && review.author.equals(currentUser._id)) { %>
          <form
            action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>?_method=DELETE"
            method="POST"
          >
            <button class="btn btn-sm btn-outline-danger rounded-pill">
              Delete
            </button>
          </form>
          <% } %>
        </div>
        <p class="starability-result mb-2" data-rating="<%= review.rating %>">
          Rated: <%= review.rating %> stars
        </p>
        <p class="card-text text-muted mb-0"><%= review.body %></p>
      </div>
    </div>
    <% } %>
  </div>
</div>

<script>
  const maptilerApiKey = '<%= process.env.MAPTILER_API_KEY %>';
  const coordinates = <%- JSON.stringify(campground.geometry.coordinates) %>;
  const title = '<%= campground.title %>';
</script>
<script src="/javascripts/showPageMap.js"></script>
