<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CampExplorer</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link rel="stylesheet" href="/stylesheets/home.css" />
  </head>

  <body class="d-flex text-center text-white bg-dark" data-bs-theme="dark">
    <div class="cover-container d-flex w-100 h-100 p-3 mx-auto flex-column">
      <header class="mb-auto">
        <div class="d-flex align-items-center">
          <h3 class="mb-0 fw-bold">
            <i class="bi bi-tree-fill text-success me-2"></i>CampExplorer
          </h3>
          <nav
            class="nav nav-masthead justify-content-center float-md-end ms-auto"
          >
            <a class="nav-link active" aria-current="page" href="/">Home</a>
            <a class="nav-link" href="/campgrounds">Campgrounds</a>
            <% if(!currentUser) { %>
            <a class="nav-link" href="/login">Login</a>
            <a
              class="nav-link btn btn-outline-light btn-sm ms-2 px-3 rounded-pill"
              href="/register"
              >Register</a
            >
            <% } else { %>
            <a class="nav-link" href="/logout">Logout</a>
            <% } %>
          </nav>
        </div>
      </header>

      <main class="px-3">
        <h1 class="display-3 fw-bold mb-4 text-shadow">
          Discover Your Next <span class="text-success">Adventure</span>
        </h1>
        <p class="lead mb-5 mx-auto" style="max-width: 600px; opacity: 0.9">
          Welcome to CampExplorer! Jump right in and explore our many
          campgrounds. Feel free to share some of your own and comment on
          others!
        </p>
        <a
          href="/campgrounds"
          class="btn btn-lg btn-success fw-bold px-5 py-3 rounded-pill shadow-lg hover-lift"
        >
          <i class="bi bi-compass me-2"></i> Explore Campgrounds
        </a>
      </main>

      <footer class="mt-auto text-white-50">
        <p class="mb-0">&copy; 2026 CampExplorer. All rights reserved.</p>
        <div class="scroll-indicator">
          <i class="bi bi-chevron-down"></i>
        </div>
      </footer>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
